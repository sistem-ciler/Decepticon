# =============================================================================
# Decepticon — Environment Variables
# =============================================================================
# Copy this file to .env and configure:
#   cp .env.example .env

# --- LLM API Keys (configure at least one) ---
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=sk-decepticon-master
LITELLM_SALT_KEY=sk-decepticon-salt

# --- PostgreSQL ---
POSTGRES_PASSWORD=decepticon

# --- Neo4j (Attack Chain Graph DB) ---
NEO4J_PASSWORD=decepticon-graph

# --- Model Profile ---
# eco  = per-agent tier (production default)
# max  = every agent on HIGH
# test = every agent on LOW (development / CI)
DECEPTICON_MODEL_PROFILE=eco

# --- Auth Method Priority ---
# Leave empty to auto-detect from configured keys
DECEPTICON_AUTH_PRIORITY=

# --- Benchmark Mode ---
BENCHMARK_MODE=

# --- LangSmith Tracing (optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=decepticon

# --- Ports ---
LANGGRAPH_PORT=2024
LITELLM_PORT=4000
POSTGRES_PORT=5432
WEB_PORT=3000
TERMINAL_PORT=3003
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- C2 Framework ---
COMPOSE_PROFILES=c2-sliver

# --- Paths ---
DECEPTICON_HOME=/root/.decepticon

# --- Language ---
DECEPTICON_LANGUAGE=en

# --- Version ---
DECEPTICON_VERSION=dev
VERSION=0.0.0

# --- Ollama (optional local LLM) ---
# OLLAMA_API_BASE=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5-coder-7b-instruct
